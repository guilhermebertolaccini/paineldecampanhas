# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_USER=midpainel
DATABASE_PASSWORD=change_me_secure_password
DATABASE_NAME=midpainel
DATABASE_URL=postgresql://midpainel:change_me_secure_password@postgres:5432/midpainel?schema=public

# ============================================
# REDIS
# ============================================
# O Coolify já injeta REDIS_HOST=redis e REDIS_PORT=6379
# Se você configurou senha no Redis, descomente:
# REDIS_PASSWORD=your_redis_password

# ============================================
# WORDPRESS INTEGRATION
# ============================================
WORDPRESS_URL=https://seu-wordpress.com.br
WORDPRESS_API_KEY=your_master_api_key_here

# ============================================
# NESTJS
# ============================================
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
# Origem do SPA que chama a API (obrigatório se não for o default do código). Várias: vírgula, sem espaços extras.
# Ex.: https://seu-wordpress.com.br  ou  https://wp.com,http://localhost:5173
# CORS_ORIGIN=https://seu-wordpress.com.br

# ============================================
# VALIDADOR WHATSAPP (Evolution API + storage local)
# ============================================
EVOLUTION_API_URL=https://sua-evolution.example.com
EVOLUTION_API_TOKEN=seu_token_evolution
# Opcional: diretório absoluto para ./storage/validators (padrão: process.cwd()/storage/validators)
# VALIDATOR_STORAGE_ROOT=/var/lib/midpainel/validators

# ============================================
# SQL SERVER (DB_DIGITAL — funil e telemetria)
# ============================================
# Nunca commite senhas reais. Use segredos no deploy.
# MSSQL_ENABLED=true
# MSSQL_HOST=10.103.2.26
# MSSQL_PORT=1433
# MSSQL_DATABASE=DB_DIGITAL
# MSSQL_USER=user_digital
# MSSQL_PASSWORD=
# MSSQL_ENCRYPT=true
# MSSQL_TRUST_SERVER_CERTIFICATE=true
# Se true, falha de gravação no MSSQL propaga erro (padrão: não propaga)
# MSSQL_STRICT=false

# Cron diário 06:00 — checagem de saúde (LINE_HEALTH_CRON_ENABLED=false desliga)
# LINE_HEALTH_CRON_ENABLED=true
# JSON: [{ "provider": "NOAH_OFICIAL", "envId": "373", "nome_linha": "Linha A", "health_url": "https://..." }]
# LINE_HEALTH_TARGETS=[]

# Webhook POST /webhooks/salesforce/tracking — se vazio, rota aberta (recomendado definir em produção)
# SALESFORCE_TRACKING_WEBHOOK_SECRET=
