# ==============================================================================
# .env.example — sync_indicadores.py
# ==============================================================================
#
# Uso:
#   1) Copie este arquivo para `.env` no mesmo diretório de sync_indicadores.py.
#   2) Preencha os valores reais (segredos devem viver no .env, NUNCA commitados).
#   3) Rode: `python sync_indicadores.py`.
#
# O script carrega o .env automaticamente via `python-dotenv` (load_dotenv()).
# Variáveis sem default são obrigatórias.
# ==============================================================================


# ─── 1) Destino: SQL Server (.26 — onde mora dbo.indicadores_digital) ─────────
# Engine: mssql+pyodbc com fast_executemany=True. Driver ODBC 18 com
# TrustServerCertificate=yes (default). Senhas com caracteres especiais são
# URL-encoded automaticamente pelo script.

MSSQL_SERVER=
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=

# Schema do destino (default: dbo). A tabela final é `${MSSQL_SCHEMA}.indicadores_digital`.
MSSQL_SCHEMA=dbo

# Driver ODBC. Em servidores Windows costuma ser "ODBC Driver 18 for SQL Server"
# (default). Em Linux com pyodbc/unixODBC, valide o nome com `odbcinst -q -d`.
MSSQL_ODBC_DRIVER=ODBC Driver 18 for SQL Server


# ─── 2) Origem GRC: SQL Server da Ótima (TB_WEBHOOK_GOSAC_EVENTO_INDICADOR) ───
# Origem da Ótima. Se essas variáveis ficarem vazias o script desabilita o
# pipeline GRC (apenas WordPress roda) e retorna exit_code=2 ao final.

MSSQL_GRC_SERVER=
MSSQL_GRC_DATABASE=
MSSQL_GRC_USER=
MSSQL_GRC_PASSWORD=

# Driver ODBC da origem GRC (opcional). Se vazio, usa MSSQL_ODBC_DRIVER.
MSSQL_GRC_ODBC_DRIVER=

# Filtro de data na subquery de deduplicação do GRC. Aceita:
#   - DATA       → TRY_CAST([DATA] AS DATE) = <date_filter>
#   - DATA_ENVIO → TRY_CAST([DATA_ENVIO] AS DATE) = <date_filter>
#   - EITHER     → DATA OR DATA_ENVIO  (default — recomendado em produção)
MSSQL_GRC_FILTER_DATE=EITHER

# Modo debug: define como 1 para pular completamente o filtro de data no GRC
# (extrai TUDO da fornecedora alvo, ignorando a janela). Use só para
# investigar 0 linhas — em produção mantenha vazio.
MSSQL_GRC_SKIP_DATE_FILTER=

# Diagnóstico automático: quando GRC retorna 0 linhas no período, o script
# imprime contagens por fornecedor + faixa de datas + top dias com volume.
# Defina como "0" para silenciar (default: 1 = ligado).
ETL_GRC_AUTO_DIAG=1


# ─── 3) Origem WordPress: REST `/wp-json/pc/v1/export/indicadores` ────────────
# Endpoint protegido por X-API-KEY (Master API Key). O script usa format=csv
# (delimitado por ';') por padrão e faz streaming chunked com pandas.

# URL base do painel (sem barra final). Ex.: https://painel.exemplo.com.br
WP_BASE_URL=

# Master API Key configurada em wp_options (acm_master_api_key).
# Mesma chave aceita pelo `permission_callback` => check_api_key_rest.
WP_X_API_KEY=

# Retry em 5xx do endpoint REST (defaults: 3 tentativas, 2.5s entre cada).
WP_HTTP_RETRIES=3
WP_HTTP_RETRY_SEC=2.5


# ─── 4) Janela de datas (compartilhada por WP + GRC) ──────────────────────────
# Ordem de precedência: ETL_INDICADORES_DAYS_BACK > ETL_INDICADORES_DATE.
#
# Cenário recomendado para cron diário (1 vez por dia, 04:00):
#   ETL_INDICADORES_DAYS_BACK=1
#   ETL_INDICADORES_DAYS_OFFSET=1
#   → processa apenas D-1 (ontem), evita corrida com webhooks atrasados do dia.
#
# Cenário "rebuild histórico" (uma vez, depois desliga):
#   ETL_INDICADORES_DAYS_BACK=  (vazio)
#   ETL_INDICADORES_DATE=all
#   → puxa tudo o que o WP/GRC devolverem sem filtro de data.
#
# Cenário "re-process última dezena" (corrige falhas pontuais):
#   ETL_INDICADORES_DAYS_BACK=10
#   ETL_INDICADORES_DAYS_OFFSET=1   → ontem … ontem-9

# Tamanho da janela em dias (>=1). Vazio = usar ETL_INDICADORES_DATE em vez disso.
ETL_INDICADORES_DAYS_BACK=

# Onde começar a contar (>=0):
#   0 → começa em hoje (D-0)
#   1 → começa em ontem (D-1) — recomendado para cron diário
ETL_INDICADORES_DAYS_OFFSET=0

# Modo "1 dia só" (só usado quando ETL_INDICADORES_DAYS_BACK está vazio):
#   - vazio       → D-0 (hoje)
#   - all         → histórico completo (sem filtro de data)
#   - YYYY-MM-DD  → data específica (validada por regex)
ETL_INDICADORES_DATE=
